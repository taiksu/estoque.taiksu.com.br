<style>
    .menu-card{
        opacity:0;
        transform: translateY(10px);
        transition: opacity .2s ease, transform .4s ease;
    }

    .menu-card.show{
        opacity:1;
        transform: translateY(0);
    }
</style>

<div class="w-full flex flex-row items-center justify-between my-6 md:px-0 px-2">

    <div class="menu-card flex flex-col items-center gap-2 group">
        <a href="/comprar" class="bg-white md:p-8 p-4 rounded-full border border-gray-200 hover:shadow-lg transition-shadow duration-300">
            <img class="md:h-9 md:w-9 h-7 w-7 opacity-90 group-hover:opacity-100 transition-all duration-300" src="/images/icones/comprar.png">
        </a>
        <p class="text-gray-500 group-hover:text-gray-700 md:text-sm text-xs font-medium">Comprar</p>
    </div>

    <div class="menu-card hidden md:flex flex-col items-center gap-2 group">
        <a href="/historico" class="bg-white md:p-8 p-4 rounded-full border border-gray-200 hover:shadow-lg transition-shadow duration-300">
            <img class="md:h-9 md:w-9 h-7 w-7 opacity-90 group-hover:opacity-100 transition-all duration-300" src="/images/icones/historico.png">
        </a>
        <p class="text-gray-500 group-hover:text-gray-700 md:text-sm text-xs font-medium">Histórico</p>
    </div>

    <div class="menu-card flex flex-col items-center gap-2 group">
        <div class="bg-white md:p-8 p-4 rounded-full border border-gray-200 hover:shadow-lg transition-shadow duration-300">
            <img class="md:h-9 md:w-9 h-7 w-7 opacity-90 group-hover:opacity-100 transition-all duration-300" src="/images/icones/balanco.png">
        </div>
        <p class="text-gray-500 group-hover:text-gray-700 md:text-sm text-xs font-medium">Balanço</p>
    </div>

    <div class="menu-card flex flex-col items-center gap-2 group">
        <a href="/saida" class="bg-white md:p-8 p-4 rounded-full border border-gray-200 hover:shadow-lg transition-shadow duration-300">
            <img class="md:h-9 md:w-9 h-7 w-7 opacity-90 group-hover:opacity-100 transition-all duration-300" src="/images/icones/saida.png">
        </a>
        <p class="text-gray-500 group-hover:text-gray-700 md:text-sm text-xs font-medum">Saída</p>
    </div>

    <div class="menu-card flex flex-col items-center gap-2 group">
        <a href="/entrada" class="bg-white md:p-8 p-4 rounded-full border border-gray-200 hover:shadow-lg transition-shadow duration-300">
            <img class="md:h-9 md:w-9 h-7 w-7 opacity-90 group-hover:opacity-100 transition-all duration-300" src="/images/icones/entrada.png">
        </a>
        <p class="text-gray-500 group-hover:text-gray-700 md:text-sm text-xs font-medium">Entrada</p>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {

        const cards = document.querySelectorAll(".menu-card");

        setTimeout(() => {  
            cards.forEach((card, index) => {
                setTimeout(() => {
                    card.classList.add("show");
                }, index * 100);
            });

        }, 450);

    });
</script>