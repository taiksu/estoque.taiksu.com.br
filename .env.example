# ==============================
# Ambiente Geral da Aplicação
# ==============================
NODE_ENV=development
PORT=3071
APP_TRUST_PROXY=1

# ==============================
# Sessão / Cookie
# ==============================
SESSION_SECRET=change-this-session-secret
SESSION_COOKIE_NAME=TaiksuEstoqueCookie
SESSION_COOKIE_MAX_AGE_MS=7200000
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax

# ==============================
# Banco de Dados (App)
# ==============================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=estoqueDB
DB_USER=estoqueUser
DB_PASSWORD=change-this-db-password
DB_DIALECT=mysql

# ==============================
# Banco de Dados (Sequelize CLI)
# ==============================
DB_URL=mysql://estoqueUser:change-this-db-password@127.0.0.1:3306/estoqueDB
TEST_DB_URL=mysql://root:@127.0.0.1:3306/database_test
PROD_DB_URL=mysql://root:@127.0.0.1:3306/database_production

# ==============================
# SSO / Autenticação Externa
# ==============================
SSO_USER_ME_URL=https://login.taiksu.com.br/api/user/me

# ==============================
# Event Broker (publishEvent.js)
# ==============================
EVENT_BROKER_BASE_URL=http://127.0.0.1:3093
EVENT_BROKER_PUBLISH_PATH=/api/event
EVENT_BROKER_SERVICE_TOKEN=change-this-service-token

