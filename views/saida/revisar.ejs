<%- include('../components/toast', { sucess: true, texto: 'Saida de estoque finalizada com sucesso', id: 'sucesso-toast' }); %>
<%- include('../components/toast', { sucess: false, texto: 'Não há estoque suficiente de<br> <span class="font-semibold text-red-600" id="falha-insumo"></span><br> para a retirada.', id: 'falha-toast' }); %>


<div id="container-saida">
    <div class="flex flex-row items-center justify-between">
        <%- include('../components/breadcrumb', { link: '/saida', paginaAnterior: 'Saida manual'}) %>
    </div>

    <%- include('../partials/containerListaSaida') %>

    <%- include('../partials/termosSaida') %>

    <button id="finalizar-saida" class="hidden w-full cursor-pointer bg-green-600 text-white py-3 rounded-full hover:bg-green-700 transition-colors duration-300">
        Confirmar saída
    </button>
</div>

<script>
    const finalizarSaida = document.getElementById('finalizar-saida');
    const sucessoToast = document.getElementById('sucesso-toast');
    const containerSaida = document.getElementById('container-saida');
    const falhaToast = document.getElementById('falha-toast');
    const toastText = document.getElementById('toast-text');
    const unidade_id = <%= unidade_id %>;

    finalizarSaida.addEventListener('click', async () => {
        const response = await fetch('/api/saida/manual', {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                unidade_id
            })
        });

        const data = await response.json();
        console.log(data);
        
        // Aviso se o estoque estiver baixo
        if(data.motivo === 'estoque-baixo') {
            const falhaInsumo = document.getElementById('falha-insumo');

            //Busca nome do insumo na API
            const response = await fetch(`https://insumos.taiksu.com.br/insumos/${data.insumo_id}`);
            const dataInsumo = await response.json();
            falhaInsumo.textContent = dataInsumo.nome;

            falhaToast.classList.remove('hidden');
            setTimeout(() => {
                falhaToast.classList.add('hidden');
                window.location.reload()
            }, 2000);
        }

        if(data.success) {
            containerSaida.remove();
            sucessoToast.classList.remove('hidden');
            setTimeout(() => {
                window.location.href = '/';
            }, 1500);
        } else {
            toastText.textContent = data.mensagem;
            falhaToast.classList.remove('hidden');
            setTimeout(() => {
                falhaToast.classList.add('hidden');
            }, 2000);
        }
    });
</script>