<div class="flex flex-row items-center justify-between">
    <%- include('../components/breadcrumb', { link: '/', paginaAnterior: 'Estoque'}) %>
</div>

<div class="flex flex-col gap-4 mt-5">
    <a href="/entrada/manual" class="flex flex-row items-center justify-between border border-gray-200 rounded-xl p-6 bg-white hover:shadow-lg transition-shadow duration-300 cursor-pointer">

        <div class="flex flex-row items-center gap-4">
            <img src="/images/icones/manual.png" class="w-8 h-8">
            <div>
                <h1 class="font-semibold text-gray-600">Entrada manual</h1>
                <p class="text-sm text-gray-500">Monte uma lista de entrada manualmente</p>
            </div>
        </div>
        <img src="https://login.taiksu.com.br/frontend/img/seta.png" class="w-5 h-5">
    </a>

    <a href="/entrada/nfe" class="flex flex-row items-center justify-between border border-gray-200 rounded-xl p-6 bg-white hover:shadow-lg transition-shadow duration-300 cursor-pointer">

        <div class="flex flex-row items-center gap-4">
            <img src="/images/icones/nfe.png" class="w-8 h-8">
            <div>
                <h1 class="font-semibold text-gray-600">Através da NF-e</h1>
                <p class="text-sm text-gray-500">Ideal para notinhas de supermercado</p>
            </div>
        </div>
        <img src="https://login.taiksu.com.br/frontend/img/seta.png" class="w-5 h-5">
    </a>
</div>

<div class="flex flex-col gap-2 mt-14">
    <h1 class="text-sm text-gray-500 ml-1">Entrada por pedido</h1>
    <div class="flex flex-col gap-3" id="pedidos-pendentes"></div>
</div>

<script>
    const pedidos_pendentes = document.getElementById('pedidos-pendentes');

    fetch(`https://pedidos.taiksu.com.br/api/pedidos/recentes/<%= unidade_id%>`)
        .then(res => res.json())
        .then(data => {
            if (data.length === 0) {
                pedidos_pendentes.innerHTML = `
                    <div class="flex flex-col gap-1 items-center justify-center rounded-xl border border-gray-200 p-10 bg-white">
                        <img src="/images/icones/pacote.png" class="w-16 h-16 mb-2">
                        <h3 class="text-xl font-semibold text-gray-600">Não há pedidos pendentes para dar entrada</h3>
                        <p class="text-sm text-gray-500 text-center">Quando houver pedidos pendentes eles aparecerão aqui<br> para você dar entrada no estoque de forma rápida</p>
                    </div>
                `;
            } else {
                data.forEach(pedido => {
                    pedidos_pendentes.innerHTML += `
                        <a href="/entrada/pedido/${pedido.id}" class="group flex flex-row items-center justify-between border border-gray-200 rounded-xl px-6 py-5 bg-white">
                            <div class="flex flex-row items-center gap-4">
                                <img src="/images/icones/pacote.png" class="w-10 h-10 p-0.5 rounded-lg bg-gray-100 group-hover:bg-green-100 transition-colors duration-200">
                                <div>
                                    <h1 class="font-medium text-sm text-gray-500">${pedido.nome}</h1>
                                    <p class="text-xs text-gray-400">${Number(pedido.valor_total).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</p>
                                </div>
                            </div>
                            <img src="https://login.taiksu.com.br/frontend/img/seta.png" class="w-5 h-5">
                        </a>
                    `;
                });
            }
        });
</script>
