<%
let icone;
if (sucess === true) {
    icone = '/images/icones/certo.png';
    cor = 'text-green-700';
} else {
    icone = '/images/icones/falha.png';
    cor = 'text-red-800';
}
%>

<!--Conteincer centralizado na tela-->
<div id="<%= id %>" class="hidden bg-black/20 backdrop-blur-sm fixed top-0 left-0 w-full h-full flex items-center justify-center">
    <div class="w-full max-w-md flex flex-col items-center gap-6 py-24 px-8 bg-white rounded-xl">
        <img src="<%= icone %>" class="h-12 w-12">
        <h2 id="toast-text" class="text-lg text-center <%= cor %>"><%- texto %></h2>
    </div>
</div>