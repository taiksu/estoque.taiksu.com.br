<div class="flex flex-row items-center justify-between">
    <%- include('../../components/breadcrumb', { link: '/entrada', paginaAnterior: 'Entrada'}) %>
    <a id="revisar-entrada" href="/entrada/manual/revisar" class="flex flex-row gap-2 items-center rounded-full bg-white border border-gray-200 pl-4 pr-2 py-1 text-gray-600 font-medium shadow-xl hover:shadow-none transition-all duration-300">
        Revisar entrada
        <img src="https://login.taiksu.com.br/frontend/img/seta.png" class="w-5 h-5">
    </a>
</div>


<%- include('../../components/searchBox', { placeholder: 'Pesquisar insumo' }) %>

<div id="container-insumos" class="flex flex-col gap-3">
    <!-- O conteúdo do container será adicionado dinamicamente -->
</div>

<div id="modal-adicionar-carrinho" class="hidden bg-black/20 backdrop-blur-sm fixed top-0 left-0 w-full h-full flex flex-col gap-4 items-center px-8 justify-center">
    <div class="bg-white rounded-xl p-8 w-full max-w-md border border-gray-200">
        <div id="modal-content" class="flex flex-col gap-4">
            <!-- O conteúdo do modal será adicionado dinamicamente -->
        </div>
    </div>
    <div id="fechar-popup" class="cursor-pointer bg-white text-gray-500 text-sm px-3 py-1 rounded-full opacity-70 hover:opacity-80 transition-all duration-600 flex flex-row gap-1 items-center">
        <img class="h-5 grayscale" src="/images/icones/falha.png">
        Fechar janela
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async function() {

        //// Elementos do DOM
        const container = document.getElementById('container-insumos');
        const modal = document.getElementById('modal-adicionar-carrinho');
        const modalContent = document.getElementById('modal-content');
        const close = document.getElementById('fechar-popup');

        //// Busca os insumos na API
        const response = await fetch('https://insumos.taiksu.com.br/insumos?visibilidade=estoque')
        const categorias = await response.json();

        //// Busca fornecedores
        const responseFornecedores = await fetch('https://insumos.taiksu.com.br/fornecedores')
        const fornecedores = await responseFornecedores.json();

        //// Função para mostrar o toast
        function mostrarToast() {
            toast.classList.remove('hidden');
            toast.classList.add('flex');
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('flex');
            }, 800);
        }


        //// Popula a lista de insumos
        Object.keys(categorias).forEach(categoria => {
            const divCategoria = document.createElement('div');
            divCategoria.className = 'flex flex-col gap-1 my-4 categoria-insumos';
            divCategoria.innerHTML = `
                <h2 class="text-sm text-gray-500">${categoria}</h2>
                <div class="flex flex-col gap-3">
                    ${categorias[categoria].map(insumo => `
                            <div id="card-insumo-${insumo.id}" data-insumo-id="${insumo.id}" class="group cursor-pointer insumo-card flex flex-row items-center justify-between bg-white border border-gray-200 rounded-xl p-4 hover:shadow-lg transition-all duration-400">

                                <div class="flex flex-row items-center gap-2">
                                    <img class="insumo-foto md:h-12 md:w-12 h-10 w-10 rounded-md bg-white group-hover:scale-110 transition-all duration-400" 
                                         src="https://insumos.taiksu.com.br/${insumo.foto_url}">
                                    
                                    <div class="flex flex-col gap-0">
                                        <h3 class="insumo-nome md:text-md text-sm text-gray-600 font-medium">
                                            ${insumo.nome}
                                        </h3>
                                        <p data-valor-maximo-${insumo.id}="${insumo.valor_maximo}" class="hidden">${insumo.valor_maximo}</p>
                                        <p id="unidade-${insumo.id}" class="text-xs text-gray-400">${insumo.unidade_medida}</p>
                                    </div>
                                </div>

                                <div id="adicionado-${insumo.id}" data-adicionado-id="${insumo.id}" class="hidden flex flex-row items-center gap-1 bg-green-50 rounded-full px-2 py-1">
                                    <img src="https://estoque.taiksu.com.br/images/icones/certo.png" class="h-5 w-5">
                                    <h3 class="text-sm font-medium text-green-700">Adicionado</h3>
                                </div>
                            </div>
                    `).join('')}
                </div>
            `;
            container.appendChild(divCategoria);
        });

        // Busca a lista de entrada
        const responseListaEntrada = await fetch(`https://estoque.taiksu.com.br/api/lista-entrada?unidade_id=<%= unidade_id %>`);
        const dataListaEntrada = await responseListaEntrada.json();

        if(responseListaEntrada.ok) {
            const info_lista = dataListaEntrada.info_lista;
            const insumos_entrada = dataListaEntrada.insumos_entrada;

            // Mostra os insumos que já estão na lista de entrada
            insumos_entrada.forEach(insumoEntrada => {
                const flagAdicionado = document.getElementById('adicionado-' + insumoEntrada.insumo_id);
                flagAdicionado.classList.remove('hidden');
            });
        }


        //// Interações para abrir o pop-up ao clicar no card do insumo
        const insumos = document.querySelectorAll('.insumo-card');

        insumos.forEach(insumo => {
            insumo.addEventListener('click', async function() {
                const insumoId = this.getAttribute('data-insumo-id');
                const insumoNome = this.querySelector('.insumo-nome').textContent;
                const insumoFoto = this.querySelector('.insumo-foto').src;
                const valorMaximo = Number(document.querySelector('[data-valor-maximo-' + insumoId + ']').textContent);
                const unidadeMedida = document.getElementById('unidade-' + insumoId).textContent;
                let placeholderQuantidade = '1 uni';

                if (unidadeMedida == 'kg') {
                    placeholderQuantidade = '0.000 kg';
                }

                // Abre o modal
                modal.classList.remove('hidden');
                modalContent.innerHTML = `
                    <div class="flex flex-col gap-4">

                        <div class="flex flex-row items-center gap-2">
                            <img src="${insumoFoto}" class="md:h-16 md:w-16 h-10 w-10 rounded-md bg-white border border-gray-100">
                            <div class="flex flex-col gap-0 mt-1">
                                <h2 class="text-sm text-gray-500">Adicionando ao estoque</h2>
                                <h2 class="text-xl text-gray-700 font-semibold">${insumoNome}</h2>
                            </div>
                        </div>

                        <div class="flex flex-col gap-1">
                            <h2 class="text-xs text-gray-500">Fornecedor</h2>
                            <select id="fornecedor" class="w-full p-2 border border-gray-200 outline-none rounded-md appearance-none">
                                <option disabled selected value="">Selecione um fornecedor</option>
                            </select>
                        </div>  

                        <div id="modal-content-quantidade" class="w-full flex flex-col items-start gap-1 mt-1">
                            <div class="w-full flex flex-row items-center gap-4">
                                <div class="w-full flex flex-col gap-1">
                                    <h2 class="text-xs text-gray-500">Preço</h2>    
                                    <input type="number" id="preco" class="w-full focus:outline-none p-2 border border-gray-200 rounded-md" placeholder="${valorMaximo.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}">
                                </div>
                                <div class="flex flex-col items-center justify-center text-md font-bold text-gray-600 mt-5">X</div>
                                <div class="flex flex-col gap-1">
                                    <h2 class="text-xs text-gray-500">Quantidade</h2>
                                    <input type="number" id="quantidade" class="w-full focus:outline-none p-2 border border-gray-200 rounded-md" placeholder="${placeholderQuantidade}">
                                </div>
                            </div>
                            <p data-valor-maximo-${insumoId} class="text-xs text-gray-400 ml-1">Máx: ${valorMaximo.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</p>
                        </div>
                        <div class="flex flex-row items-center justify-between mt-4">
                            <h3 class="text-md text-gray-600">Total:</h3>
                            <h2 id="preco-total" class="text-md text-green-700 font-semibold">R$ 0,00</h2>
                        </div>
                        <button data-insumo-id="${insumoId}" id="adicionar-lista" class="mt-2 cursor-pointer w-full p-2 bg-green-600 hover:bg-green-700 transition-all duration-300 text-white rounded-full">Adicionar à lista</button>

                    </div>
                `;

                // Popula o select de fornecedores
                const fornecedorSelect = document.getElementById('fornecedor');
                fornecedores.forEach(fornecedor => {
                    const option = document.createElement('option');
                    option.value = fornecedor.id;
                    option.text = fornecedor.nome;
                    fornecedorSelect.appendChild(option);
                });

                // Calcula o preço total
                document.getElementById('quantidade').addEventListener('input', function() {
                    const quantidade = this.value;
                
                    if(quantidade <= 0 && unidadeMedida == 'uni') {
                        this.value = 1;
                    }
                    const preco = document.getElementById('preco').value;
                    const precoTotal = quantidade * preco;
                    document.getElementById('preco-total').textContent = precoTotal.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                });

                // Botão adicionar à lista
                const adicionarListaButton = document.getElementById('adicionar-lista');
                adicionarListaButton.addEventListener('click', async function() {
                    const quantidade = document.getElementById('quantidade').value;
                    const fornecedorId = document.getElementById('fornecedor').value;
                    const preco = document.getElementById('preco').value;
                    const insumoId = this.getAttribute('data-insumo-id');
                    const flagAdicionado = document.getElementById('adicionado-' + insumoId);
                    const responsavelId = <%= user_id %>;
                    const unidadeId = <%= unidade_id %>;

                    // Bloqueia valor maior que o máximo ou zero
                    if(preco > valorMaximo || preco <= 0) {
                        document.getElementById('preco').classList.add('border-red-500');
                        document.getElementById('preco').classList.add('bg-red-50')
                        setTimeout(() => {
                            document.getElementById('preco').classList.remove('border-red-500');
                            document.getElementById('preco').classList.remove('bg-red-50')
                        }, 2000);
                        return;
                    }

                    // Obriga seleciona fornecedor
                    if(fornecedorId === '') {
                        alert('Selecione um fornecedor');
                        return;
                    }

                    // Obriga quantidade maior que 0
                    if(quantidade <= 0) {
                        alert('Quantidade inválida');
                        return;
                    }

                    const response = await fetch('https://estoque.taiksu.com.br/api/lista-entrada/add', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            insumo_id: insumoId,
                            preco: Number(preco).toFixed(2),
                            quantidade,
                            fornecedor_id: fornecedorId,
                            unidade_id: unidadeId,
                            responsavel_id: responsavelId
                        })
                    });

                    const data = await response.json();

                    if(response.ok) {
                        // Atualiza a lista de entrada e fecha o modal
                        modalContent.innerHTML = `
                            <div class="flex flex-col items-center gap-2 py-24">
                                <img src="https://estoque.taiksu.com.br/images/icones/certo.png" class="h-12 w-12">
                                <h2 class="text-lg text-gray-600"><span class="font-semibold text-green-700">${insumoNome} </span> adicionado à lista de entrada.</h2>
                            </div>
                        `;
                        flagAdicionado.classList.remove('hidden');
                        setTimeout(() => {
                            modal.classList.add('hidden');
                            modalContent.innerHTML = '';
                        }, 800);
                    } else {
                        alert('Falha ao adicionar item à lista de entrada, tente novamente.');
                        throw new Error('Falha ao adicionar item à lista de entrada');
                    }
                });


            });
        });

        //// Fecha no botão
        close.addEventListener('click', (event) => {
            if (event.target === close) {
                modal.classList.add('hidden');
                modalContent.innerHTML = '';
            }
        });

        //// Fecha o pop-up ao clicar fora
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                modal.classList.add('hidden');
                modalContent.innerHTML = '';
            }
        });

        //// Fecha com ESC
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                modal.classList.add('hidden');
                modalContent.innerHTML = '';
            }
        });

        // Remove card do salmão pra obrigar entrada pelo Resíduos
        const cardSalmao = document.getElementById('card-insumo-159');
        cardSalmao.remove();
    });
</script>