<div id="aviso" class="flex flex-col w-full max-w-2xl mx-auto justify-center items-center h-[50dvh]">
  <img class="h-48" src="https://vagas.taiksu.com.br/images/error/404.png">
  <h1 class="font-semibold text-gray-600 text-md">Ops, algo deu errado...</h1>
</div>

<div id="erro" class="hidden w-full p-10 mb-2 mt-48 rounded-lg bg-white border border-gray-300">
  <div class="flex flex-col gap-4 items-center mb-4">
        <p class="bg-gray-200 text-gray-600 rounded-md text-sm px-4 py-1">
      <%= error.status %>
    </p>
    <h1 class="text-lg text-gray-700 font-semibold"><%= error.message %> | <span class="text-gray-500"><%= error.name %></span></h1>
  </div>
  <p class="text-sm text-center"><%= error %></p>
</div>

<div class="flex flex-row justify-center items-center">
  <button id="alterar-div" class="rounded-full px-5 py-1 bg-gray-200 text-gray-600 text-sm cursor-pointer hover:bg-gray-300">
    Exibir detalhes do erro
  </button>
</div>

<script>
  const btn = document.getElementById('alterar-div');
  const aviso = document.getElementById('aviso');
  const erro = document.getElementById('erro');

  btn.addEventListener('click', () => {
    const mostrandoErro = !erro.classList.contains('hidden');

    if (mostrandoErro) {
      // Oculta erro e mostra aviso
      erro.classList.add('hidden');
      aviso.classList.remove('hidden');
      btn.textContent = 'Exibir detalhes do erro';
    } else {
      // Oculta aviso e mostra erro
      aviso.classList.add('hidden');
      erro.classList.remove('hidden');
      btn.textContent = 'Ocultar detalhes do erro';
    }
  });
</script>
